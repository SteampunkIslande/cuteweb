{% extends "common/base.html.j2" %}

{% block title %}Se connecter — CuteWeb{% endblock %}

{% block content %}
<div class="widget">
    <h1 class="widget-title">Se connecter</h1>

    <label for="usermail">Nom d'utilisateur</label>
    <input id="usermail" name="usermail" type="text" />

    <label for="password">Mot de passe</label>
    <input id="password" name="password" type="password" />

    <button onclick="login()">Se connecter</button>
</div>
<script>
    async function login() {
        const usermail = document.getElementById('usermail').value;
        const password = document.getElementById('password').value;

        if (!usermail.trim() || !password.trim()) {
            alert('Les deux champs sont requis');
            return;
        }

        const response = await fetch('/cuteweb/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ usermail, password })
        });

        if (!response.ok) {
            const errorData = await response.json();
            alert(errorData.message || 'Erreur de connexion');
        }

    }
</script>
{% endblock %}