{% extends "common/base.html.j2" %}

{% block title %}Projet {{ project_id }} — CuteWeb{% endblock %}

{% block head %}
<style>
    /* -----------------------------------------------------------------------
       Layout 3 colonnes :  [tab-left]  |  [main-table]  |  [tab-right]
       --------------------------------------------------------------------- */
</style>
{% endblock %}

{% block content %}

<div class="app-layout">

    {# ===== Colonne gauche : onglets (ex: Fields) ===== #}
    <div class="layout-panel panel-left">
        {% from "macros/tab_widget.html.j2" import tab_widget %}
        {{ tab_widget(
        widget_id = "left-tabs",
        tabs = [
        { "name": "Champs", "template": "fields" },
        { "name": "Filtres", "template": "filters" }
        ],
        project_id = project_id
        ) }}
    </div>

    {# ===== Colonne centrale : table principale ===== #}
    <div class="layout-panel panel-center">
        {% include "main_table/main_table.html.j2" %}
    </div>

    {# ===== Colonne droite : onglets (ex: Variant info) ===== #}
    <div class="layout-panel panel-right">
        {% from "macros/tab_widget.html.j2" import tab_widget %}
        {{ tab_widget(
        widget_id = "right-tabs",
        tabs = [
        { "name": "Info variant", "template": "variant_info" }
        ],
        project_id = project_id
        ) }}
    </div>

</div>

<script>
    // ---------------------------------------------------------------------------
    // cuteweb namespace global
    // ---------------------------------------------------------------------------
    const cuteweb = {
        /**
         * switchTab(widgetId, index)
         * Affiche l'onglet `index` (1-based) dans le widget `widgetId`.
         */
        switchTab(widgetId, index) {
            const widget = document.getElementById(widgetId);
            if (!widget) return;

            widget.querySelectorAll('.tab-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i + 1 === index);
            });
            widget.querySelectorAll('.tab-panel').forEach((panel, i) => {
                panel.classList.toggle('active', i + 1 === index);
            });
        },
    };
</script>

{% endblock %}